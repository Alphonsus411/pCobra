# Mapeo de módulos Cobra a archivos transpilados.
# La clave es la ruta usada en la instrucción `import`.
# Cada entrada puede especificar rutas para los archivos generados en los
# targets oficiales: python, rust, javascript, wasm, go, cpp, java y asm.
#
# Ejemplo:
# [modulo.co]
# version = "1.0.0"
# python = "modulo.py"
# rust = "modulo.rs"
# javascript = "modulo.js"
# wasm = "modulo.wasm"
# go = "modulo.go"
# cpp = "modulo.cpp"
# java = "modulo.java"
# asm = "modulo.asm"

[lock]
# Aún no se han registrado módulos transpilados.
