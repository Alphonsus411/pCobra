include LICENSE
include README.md
include CHANGELOG.md
include docs/MANUAL_COBRA.md
include cobra.mod
include cobra.toml
include pcobra.toml
include pyproject.toml
include Makefile
include scripts/install.sh
include scripts/run.sh
include .env.example

prune docs/historico
prune docs/experimental

recursive-include src/pcobra *.py
recursive-include src/pcobra *.toml
recursive-include src/pcobra *.yaml
recursive-include src/pcobra *.json
recursive-include src/pcobra *.ini
recursive-include src/pcobra *.cfg
recursive-include src/pcobra *.md
recursive-include src/pcobra *.txt
recursive-include src/pcobra *.html

# Recursos no Python específicos de cobra_installer necesarios para runtime/spec/templates.
recursive-include src/pcobra/cobra_installer *.toml *.yaml *.yml *.json *.ini *.cfg *.md *.txt *.html *.j2 *.template

recursive-include notebooks *
recursive-include docs/frontend *
